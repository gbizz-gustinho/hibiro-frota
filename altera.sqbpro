DROP TABLE IF EXISTS &quot;login_usuarios&quot;;

-- Cria a tabela definitiva para o SaaS
CREATE TABLE &quot;login_usuarios&quot; (
    &quot;id&quot; INTEGER PRIMARY KEY AUTOINCREMENT,
    &quot;nome&quot; TEXT NOT NULL,
    &quot;email&quot; TEXT NOT NULL UNIQUE,
    &quot;senha&quot; TEXT NOT NULL, -- Senha criptografada (bcrypt)
    &quot;id_empresa&quot; INTEGER, -- Chave Estrangeira (O elo com a empresa)
    &quot;created_at&quot; TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY(&quot;id_empresa&quot;) REFERENCES &quot;cad_empresa&quot;(&quot;id_empresa&quot;)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
